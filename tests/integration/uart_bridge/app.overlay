/*
 * An emulated UART standing in for uart1. uart_bridge is board-agnostic (main.c
 * passes it the device), so the real driver glue can be driven here with no
 * board and no BLE stack.
 */

/ {
	euart0: uart_emul0 {
		compatible = "zephyr,uart-emul";
		status = "okay";
		current-speed = <115200>;
		rx-fifo-size = <256>;
		tx-fifo-size = <256>;
	};
};
