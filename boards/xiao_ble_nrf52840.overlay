/*
 * nrfProxy — UART1 for incoming serial data on the Seeed XIAO BLE (nRF52840).
 *
 * Uses UARTE1 (independent of the board's uart0/i2c1/spi2), routed to two of
 * the free castellated pads. Wiring (share a common GND with your source!):
 *   Device TX  ->  D1 / P0.03  (XIAO RX)   serial device -> phone
 *   Device RX  <-  D0 / P0.02  (XIAO TX)   phone -> serial device
 *
 * D0/D1 are otherwise unused (D4/D5=I2C, D6/D7=uart0, D8-D10=SPI are taken).
 * The console/log output is over USB CDC-ACM on this board (no debug UART),
 * so view logs on the USB serial port, not a pad. Change current-speed to
 * match your source's baud rate (defaults to 115200).
 */

#include <zephyr/dt-bindings/pinctrl/nrf-pinctrl.h>
#include <zephyr/dt-bindings/regulator/nrf5x.h>
#include <zephyr/dt-bindings/gpio/gpio.h>

/*
 * Enable the nRF52840's main DC/DC regulator (REG1) for lower active/radio
 * current than the default LDO. Requires the external inductor between DCC and
 * DEC4, which the XIAO BLE has populated. VDDH is tied to VDD (normal-voltage
 * mode), so REG0 is unused and left alone.
 */
&reg1 {
	regulator-initial-mode = <NRF5X_REG_MODE_DCDC>;
};

/ {
	/* Status-LED roles -> the XIAO's on-board RGB LED (all active-low). */
	aliases {
		led-connected = &led1;    /* green */
		led-advertising = &led2;  /* blue  */
		led-error = &led0;        /* red   */

		/* Bond-reset button on the D2 pad (see the gpio-keys node
		 * below). Hold to GND through boot ~3 s to wipe the pairing. */
		bond-reset = &bond_reset_key;
	};

	/*
	 * The XIAO has no on-board user button. Wire a momentary switch (or a
	 * tweezer short) from the D2 pad (P0.28) to GND; the internal pull-up +
	 * active-low means "pressed" = shorted to GND. D2/D3 are the only free
	 * pads (D0/D1 = uart1, D4/D5 = i2c1, D6/D7 = uart0, D8-D10 = spi2). Use
	 * D3 = P0.29 instead by changing the pin below.
	 */
	gpio_keys {
		compatible = "gpio-keys";
		bond_reset_key: bond_reset_key {
			gpios = <&gpio0 28 (GPIO_PULL_UP | GPIO_ACTIVE_LOW)>;
			label = "Bond reset";
		};
	};
};

&pinctrl {
	uart1_default: uart1_default {
		group1 {
			psels = <NRF_PSEL(UART_TX, 0, 2)>;
		};
		group2 {
			psels = <NRF_PSEL(UART_RX, 0, 3)>;
			bias-pull-up;
		};
	};

	uart1_sleep: uart1_sleep {
		group1 {
			psels = <NRF_PSEL(UART_TX, 0, 2)>,
				<NRF_PSEL(UART_RX, 0, 3)>;
			low-power-enable;
		};
	};
};

&uart1 {
	status = "okay";
	current-speed = <115200>;
	pinctrl-0 = <&uart1_default>;
	pinctrl-1 = <&uart1_sleep>;
	pinctrl-names = "default", "sleep";
};
