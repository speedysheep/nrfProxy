/*
 * nrfProxy — UART1 for incoming serial data on the Nordic nRF52840 Dongle
 * (PCA10059). This is a debug/bench board: console + logging come out the USB
 * CDC-ACM serial port (the dongle has no debugger / no VCOM).
 *
 * The dongle ships with the Nordic Open USB bootloader (no J-Link). Flash by
 * DFU, not `west flash`/J-Link — see "nRF52840 Dongle" in CLAUDE.md. The app
 * links at flash offset 0x1000 (right after the factory MBR).
 *
 * Wiring (share a common GND with your serial source!):
 *   Device TX  ->  P0.13  (dongle RX)   serial device -> phone
 *   Device RX  <-  P0.15  (dongle TX)   phone -> serial device
 *
 * P0.13 / P0.15 are free, broken-out castellated pads (uart0=P0.20/17/24/22,
 * i2c0=P0.26/27, spi1=P0.31/30/P1.13, LEDs/pwm0=P0.06/08/P1.09/P0.12 are taken).
 * Change current-speed to match your source's baud rate (defaults to 115200).
 *
 * DC/DC: the dongle's board dts already enables REG1 in DC/DC mode (it has the
 * inductor), so there's nothing to add here.
 */

#include <zephyr/dt-bindings/pinctrl/nrf-pinctrl.h>

/ {
	/*
	 * Status-LED roles -> the dongle's RGB LED (LD2), all active-low. Unlike the
	 * single-LED Pro Micro, the dongle has a full RGB LED, so the error role gets
	 * its own (red) colour here.
	 */
	aliases {
		led-connected = &led1_green;    /* P1.09 green */
		led-advertising = &led1_blue;   /* P0.12 blue  */
		led-error = &led1_red;          /* P0.08 red   */
	};

	/*
	 * The board routes these RGB LED pins through pwm0 (pwmleds). We drive them
	 * as plain GPIOs, so disable the PWM peripheral and the pwm-leds node to avoid
	 * two drivers claiming the same pins.
	 */
	pwmleds {
		status = "disabled";
	};
};

&pwm0 {
	status = "disabled";
};

&pinctrl {
	uart1_default: uart1_default {
		group1 {
			psels = <NRF_PSEL(UART_TX, 0, 15)>;
		};
		group2 {
			psels = <NRF_PSEL(UART_RX, 0, 13)>;
			bias-pull-up;
		};
	};

	uart1_sleep: uart1_sleep {
		group1 {
			psels = <NRF_PSEL(UART_TX, 0, 15)>,
				<NRF_PSEL(UART_RX, 0, 13)>;
			low-power-enable;
		};
	};
};

&uart1 {
	status = "okay";
	current-speed = <115200>;
	pinctrl-0 = <&uart1_default>;
	pinctrl-1 = <&uart1_sleep>;
	pinctrl-names = "default", "sleep";
};
